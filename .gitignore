.build/
.swiftpm/
Package.resolved
Packages/

# Carthage / CocoaPods (not used, but defensive)
Carthage/Build/
Pods/

# Pilo runtime state (lives in ~/Library/Application Support/Pilo)
# never inside repo

# Editor
.vscode/
.idea/
*.swp
*~

# Internal-only docs & scripts —— 保留在本地，不上传公开 repo
# 维护者笔记 / AI 开发指南 / 个人 release 流脚本
IMPLEMENTATION.md
CLAUDE.md
scripts/

# Release artifacts —— release.sh 打的 zip 不上传 repo（用 GitHub Release 上传）
Pilo-v*.zip
*.dmg

# 本地构建日志 + 临时工作目录（i18n 审计脚本等），只留本地不上传
build.log
scratch/
